# =============================================================================
# MedSecure - Colección de rutas API (formato .http)
# Compatible con VS Code REST Client y JetBrains HTTP Client
# =============================================================================

### Variables globales
@baseUrl = http://localhost:4000/api
@accessToken = {{login.response.body.accessToken}}
@refreshToken = {{login.response.body.refreshToken}}
@patientToken = {{getPatients.response.body.patients[0].patient_token}}
@recordId = {{getRecords.response.body.records[0].id}}

### ===========================================================================
### AUTENTICACIÓN
### ===========================================================================

### Health Check
GET {{baseUrl}}/health

### Register (admin)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "admin@medsecure.local",
  "password": "AdminSecure@2024!",
  "role": "admin"
}

### Register (doctor)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "doctor@medsecure.local",
  "password": "DoctorSecure@2024!",
  "role": "doctor"
}

### Register (patient)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "patient@medsecure.local",
  "password": "PatientSecure@2024!"
}

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@medsecure.local",
  "password": "AdminSecure@2024!"
}

### Login (MFA required response)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "doctor@medsecure.local",
  "password": "DoctorSecure@2024!"
}

### Setup MFA (requiere access token)
POST {{baseUrl}}/auth/mfa/setup
Authorization: Bearer {{accessToken}}

### Verify MFA (después de escanear QR)
POST {{baseUrl}}/auth/mfa/verify
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "token": "123456"
}

### Get current user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

### Refresh Token
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ===========================================================================
### PACIENTES
### ===========================================================================

### List patients
# @name getPatients
GET {{baseUrl}}/patients
Authorization: Bearer {{accessToken}}

### Get one patient
GET {{baseUrl}}/patients/{{patientToken}}
Authorization: Bearer {{accessToken}}

### Create patient (admin/doctor only)
POST {{baseUrl}}/patients
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fullName": "Juan Pérez García",
  "dateOfBirth": "1985-06-15",
  "phone": "+525512345678",
  "address": "Calle Principal 123, Ciudad de México",
  "emergencyContact": "María Pérez: +525598765432",
  "userId": "UUID_DEL_USUARIO"
}

### Update patient
PUT {{baseUrl}}/patients/{{patientToken}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "phone": "+525511223344",
  "address": "Nueva dirección 456"
}

### GDPR Delete - Derecho al olvido
DELETE {{baseUrl}}/patients/{{patientToken}}/gdpr-delete
Authorization: Bearer {{accessToken}}

### ===========================================================================
### EXPEDIENTES MÉDICOS
### ===========================================================================

### Create medical record
POST {{baseUrl}}/records
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "patientToken": "{{patientToken}}",
  "diagnosis": "Hipertensión arterial primaria",
  "medications": "[\"Lisinopril 10mg\", \"Amlodipina 5mg\"]",
  "history": "Paciente con presión arterial elevada desde hace 6 meses",
  "notes": "Control en 3 meses"
}

### Get patient records
# @name getRecords
GET {{baseUrl}}/records/patient/{{patientToken}}
Authorization: Bearer {{accessToken}}

### Get one record
GET {{baseUrl}}/records/{{recordId}}
Authorization: Bearer {{accessToken}}

### Update record
PUT {{baseUrl}}/records/{{recordId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "notes": "Paciente responde bien al tratamiento"
}

### Delete record (admin only - requires X-Confirm-Action)
DELETE {{baseUrl}}/records/{{recordId}}
Authorization: Bearer {{accessToken}}
X-Confirm-Action: confirmed

### ===========================================================================
### ADMIN - SEGURIDAD
### ===========================================================================

### Security events
GET {{baseUrl}}/admin/security-events
Authorization: Bearer {{accessToken}}

### Security events (unresolved only)
GET {{baseUrl}}/admin/security-events?resolved=false
Authorization: Bearer {{accessToken}}

### Resolve security event
POST {{baseUrl}}/admin/security-events/1/resolve
Authorization: Bearer {{accessToken}}
X-Confirm-Action: confirmed
Content-Type: application/json

### Audit logs
GET {{baseUrl}}/admin/audit-logs
Authorization: Bearer {{accessToken}}

### Audit logs filtered by user
GET {{baseUrl}}/admin/audit-logs?userId=USER_UUID
Authorization: Bearer {{accessToken}}

### ===========================================================================
### PRUEBAS DE SEGURIDAD
### ===========================================================================

### SQL Injection test
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "' OR 1=1; --",
  "password": "' OR '1'='1"
}

### XSS test
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "<script>alert('XSS')</script>@test.com",
  "password": "ValidPass123!"
}

### CORS test (desde Postman, el origin no se envía automáticamente)
GET {{baseUrl}}/health
Origin: https://malicious-site.com
